# Copy to .env and replace secrets before deploying.
#   cp .env.example .env && chmod 600 .env
#
# Secrets are loaded via env_file (not Compose ${VAR} interpolation), so passwords
# and keys may contain '$' without extra escaping.
#
# Local development: keep settings_dev below.
# Production: switch to settings_prod and fill the production block.

POSTGRES_DB=otwarte_dane_transportowe
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

DJANGO_SETTINGS_MODULE=OtwarteDaneTransportowe.settings_dev
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:44213
CORS_URLS_REGEX='^/(api|feed)/.*$'

# --- Production (uncomment / replace when deploying) -----------------------
# Use ./scripts/deploy.sh instead of plain docker compose (applies prod overlay).
# DJANGO_SETTINGS_MODULE=OtwarteDaneTransportowe.settings_prod
# DJANGO_SECRET_KEY=<generate: python3 -c "import secrets; print(secrets.token_urlsafe(64))">
# DJANGO_ALLOWED_HOSTS=api.example.org
#   (127.0.0.1 and localhost are added automatically in settings_prod)
# DJANGO_SECURE_SSL_REDIRECT=False
#   (default in settings_prod; TLS is handled by nginx/Caddy)
# CSRF_TRUSTED_ORIGINS=https://api.example.org
# CORS_ALLOWED_ORIGINS=https://www.example.org,https://example.org
# FEED_AUTH_ENCRYPTION_KEY=<generate Fernet key — see DEPLOYMENT.md>
# UID=1000
# GID=1000
# HOST_PROJECT_PATH=/opt/odt
# HOST_MEDIA_ROOT=/opt/odt/uploaded_data
# GUNICORN_WORKERS=3

# Shared cache (Redis). Required in production for the realtime lock + throttling.
REDIS_CACHE_URL=redis://redis:6379/2

# Comma-separated trusted reverse-proxy CIDRs (blog reaction IP limiting).
# TRUSTED_PROXY_CIDRS=

POSTGRES_HOST_PORT=5420
REDIS_HOST_PORT=6379
WEB_HOST_PORT=8000
# Bind address for the web port on the Docker host. Default 127.0.0.1 (localhost only;
# use with nginx/Caddy on the same machine). Set to 0.0.0.0 for LAN access, e.g.
# http://192.168.1.11:8020 — not recommended on a public-facing server without a firewall.
# WEB_HOST_BIND=0.0.0.0
GTFS_REALTIME_VALIDATOR_HOST_PORT=8082

CELERY_DEFAULT_CONCURRENCY=2
CELERY_FEEDS_CONCURRENCY=2

# GTFS validator worker — set on the host before first deploy:
#   sed -i "s/^DOCKER_GID=.*/DOCKER_GID=$(stat -c '%g' /var/run/docker.sock)/" .env
DOCKER_GID=959
