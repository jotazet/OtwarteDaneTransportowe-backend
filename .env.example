# Copy to .env for local development and replace secrets before sharing/deploying.

POSTGRES_DB=otwarte_dane_transportowe
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

DJANGO_SETTINGS_MODULE=OtwarteDaneTransportowe.settings_dev
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:44213
CORS_URLS_REGEX=^/(api|feed)/.*$

# --- Production only (settings_prod) -------------------------------------
# DJANGO_SETTINGS_MODULE=OtwarteDaneTransportowe.settings_prod
# Full scheme://host origins allowed to send CSRF-protected requests:
# CSRF_TRUSTED_ORIGINS=https://api.example.org
# Explicit CORS origin regexes (localhost is NOT auto-allowed in prod):
# CORS_ALLOWED_ORIGIN_REGEXES=
# Fernet key for encrypting stored feed auth credentials at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FEED_AUTH_ENCRYPTION_KEY=
# Optional tuning:
# MAX_FEED_FILE_SIZE_BYTES=209715200
# THROTTLE_ANON=60/min
# THROTTLE_LOGIN=10/min
# GUNICORN_WORKERS=3

# Shared cache (Redis). Required in production for the realtime lock + throttling.
REDIS_CACHE_URL=redis://redis:6379/2

# Comma-separated trusted reverse-proxy CIDRs. Only when the client IP matches one
# of these is the X-Forwarded-For header trusted (blog reaction IP limiting).
# Set this to your proxy's address(es) in production, e.g. 10.0.0.0/8
# TRUSTED_PROXY_CIDRS=

POSTGRES_HOST_PORT=5420
REDIS_HOST_PORT=6379
WEB_HOST_PORT=8000
GTFS_REALTIME_VALIDATOR_HOST_PORT=8082

CELERY_DEFAULT_CONCURRENCY=2
CELERY_FEEDS_CONCURRENCY=2

# Required for celery_validator_worker (GTFS Docker validator). Copy to .env:
#   cp .env.example .env
#   sed -i "s/^DOCKER_GID=.*/DOCKER_GID=$(stat -c '%g' /var/run/docker.sock)/" .env
DOCKER_GID=959
