# Copy to .env for local development and replace secrets before sharing/deploying.

POSTGRES_DB=otwarte_dane_transportowe
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

DJANGO_SETTINGS_MODULE=OtwarteDaneTransportowe.settings_dev
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:44213
CORS_URLS_REGEX=^/(api|feed)/.*$

POSTGRES_HOST_PORT=5420
REDIS_HOST_PORT=6379
WEB_HOST_PORT=8000
GTFS_REALTIME_VALIDATOR_HOST_PORT=8082

CELERY_DEFAULT_CONCURRENCY=2
CELERY_FEEDS_CONCURRENCY=2

# Required by the default GTFS validator worker on Linux:
#   DOCKER_GID=$(stat -c '%g' /var/run/docker.sock) docker compose up
DOCKER_GID=0
